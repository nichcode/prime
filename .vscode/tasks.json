{
    "tasks": [
        {
            "type": "shell",
            "label": "build prime make",
            "command" : "${workspaceFolder}/scripts/make/build_prime_make.bat",
            "options": {
                "cwd": "${workspaceFolder}/prime"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": "build",
            "detail": "Task generated by Debugger."
        },
        {
            "type": "shell",
            "label": "build tests make",
            "command" : "${workspaceFolder}/scripts/make/build_test_make.bat",
            "options": {
                "cwd": "${workspaceFolder}/tests"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": "build",
            "detail": "Task generated by Debugger."
        },
        {
            "type": "shell",
            "label": "build everything make",
            "command": "${workspaceFolder}/scripts/make/build_make.bat",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ],
    "version": "2.0.0"
}